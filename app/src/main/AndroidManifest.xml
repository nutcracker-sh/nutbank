<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Insecure permissions - nutcracker will flag these -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- VULNERABILITY: Allows sending sticky broadcasts with credentials -->
    <uses-permission android:name="android.permission.BROADCAST_STICKY" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.NutcrackerVictim"
        android:usesCleartextTraffic="true"
        android:debuggable="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- VULNERABILITY: Exported activity with no permission check -->
        <activity
            android:name=".AdminActivity"
            android:exported="true" />

        <activity android:name=".DashboardActivity" android:exported="false"/>

        <!-- VULNERABILITY: MASVS-AUTH-2 — Biometric auth with weak fallback -->
        <activity
            android:name=".BiometricAuthActivity"
            android:exported="true" />

        <!-- VULNERABILITY: MASVS-CODE-4 — Insecure WebView -->
        <activity
            android:name=".WebActivity"
            android:exported="true">
            <!-- VULNERABILITY: Loads any URL from intent data -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="nutbank" android:host="web" />
            </intent-filter>
        </activity>

        <!-- VULNERABILITY: MASVS-PLATFORM-3 — Insecure deep link handler -->
        <activity
            android:name=".DeepLinkActivity"
            android:exported="true">
            <!-- VULNERABILITY: Deep link accepts tokens via URL, no validation -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="nutbank" android:host="auth" />
            </intent-filter>
        </activity>

        <!-- Exported receiver - vulnerable -->
        <receiver
            android:name=".BroadcastReceiverHandler"
            android:exported="true">
            <intent-filter>
                <action android:name="sh.nutcracker.nutbank.SENSITIVE_ACTION" />
            </intent-filter>
        </receiver>

        <!-- Exported provider with no permission -->
        <provider
            android:name=".ContentProviderHandler"
            android:authorities="sh.nutcracker.nutbank.provider"
            android:exported="true" />

    </application>

</manifest>