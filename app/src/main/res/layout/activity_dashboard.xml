<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0f1e"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Warning banner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2a1a1a"
            android:text="⚠ VULNERABLE APP — Secrets are exposed intentionally for security research."
            android:textColor="#ff6b6b"
            android:textSize="10sp"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="20dp"/>

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome, user"
                    android:textColor="#ffffff"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Account"
                    android:textColor="#556688"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="👤"
                android:textSize="24sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ═══ Balance Card ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Total Balance"
                android:textColor="#556688"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$24,891.00"
                android:textColor="#ffffff"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Income"
                        android:textColor="#556688"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↑ $5,240.00"
                        android:textColor="#00ff88"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expenses"
                        android:textColor="#556688"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↓ $1,820.00"
                        android:textColor="#ff6b6b"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Account Details Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏦 Account Details"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Account No." android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAccountNumber" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Routing No." android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvRoutingNumber" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Account Token" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAccountToken" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="AES Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAesKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="AES IV" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAesIv" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Cloud Services Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁️ Cloud Services"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="AWS Access Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAwsAccessKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="AWS Secret Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAwsSecretKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="S3 Bucket" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvS3Bucket" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Firebase Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvFirebaseKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Firebase DB URL" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvFirebaseDbUrl" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Firebase Project" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvFirebaseProject" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Payment Gateway Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💳 Payment Gateway"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Stripe Secret Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvStripeKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Stripe Webhook Secret" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvStripeWebhook" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Communications Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📧 Communications"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="SendGrid API Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvSendGridKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Twilio Account SID" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvTwilioSid" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Twilio Auth Token" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvTwilioToken" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Twilio Phone" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvTwilioPhone" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Session & API Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑 Session &amp; API"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="API Base URL" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvApiUrl" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="API Key" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvApiKey" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="JWT Secret" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvJwtSecret" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Session Token" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvSessionToken" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffcc00" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Admin Username" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAdminUsername" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Admin Password" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvAdminPassword" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Database Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗄️ Database"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Host" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvDbHost" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="User / Password" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvDbCredentials" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Database" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvDbName" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Integrations Card ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔌 Integrations"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Google OAuth ID" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvGoogleOAuth" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Mapbox Token" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvMapboxToken" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Sentry DSN" android:textColor="#556688" android:textSize="12sp"/>
                <TextView android:id="@+id/tvSentryDsn" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#ff6b6b" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ Recent Transactions ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Recent Transactions"
            android:textColor="#8899bb"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111827"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="☕ Coffee Shop" android:textColor="#ffffff" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-$4.50" android:textColor="#ff6b6b" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="💼 Salary Deposit" android:textColor="#ffffff" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="+$5,240.00" android:textColor="#00ff88" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🛒 Supermarket" android:textColor="#ffffff" android:textSize="13sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-$89.20" android:textColor="#ff6b6b" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#334466"
            android:textSize="11sp"
            android:linksClickable="true"
            android:gravity="center"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>
